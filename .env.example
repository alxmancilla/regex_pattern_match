# Copy this file to .env and fill in your values.
# .env is listed in .gitignore — never commit real credentials.

# Required: MongoDB Atlas connection string.
# Get it from Atlas UI → Connect → Drivers → Python.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/

# Optional: defaults shown below are used if omitted.
DATABASE_NAME=regex_demo
COLLECTION_NAME=documents
SEARCH_INDEX_NAME=content_search
